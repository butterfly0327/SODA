APP_NAME=FastAPI RAG Boilerplate
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
CORS_ALLOW_ORIGINS=["*"]
RAG_TOP_K=10

# DB (asyncpg 형식: postgresql://user:pass@host:port/db)
DATABASE_URL=postgresql+asyncpg://postgres:ssafy@localhost:5433/soda

# 서울시 공공데이터 API 키
SEOUL_API_KEY=your_seoul_api_key_here

# 공용 API 키 (Gemini/OpenAPI/LLM 프록시)
GMS_API_KEY=your_api_key_here

# 데이터셋 임베딩 전용 OpenAI 키
DATASET_EMBEDDING_API_KEY=your_openai_api_key_here
# Gemini 임베딩
GEMINI_API_BASE_URL=https://gms.ssafy.io/gmsapi/generativelanguage.googleapis.com/v1beta
EMBED_MODEL=gemini-embedding-001
EMBED_DIMENSIONS=1536
EMBED_BATCH_SIZE=100

# GPT (추천/요약)
GPT_API_BASE_URL=https://gms.ssafy.io/gmsapi/api.openai.com/v1
GPT_MODEL=gpt-5-mini

# Dataset Recommendation
RECOMMENDATION_EMBEDDING_URL=https://api.openai.com/v1/embeddings
RECOMMENDATION_CHAT_URL=https://gms.ssafy.io/gmsapi/api.openai.com/v1/chat/completions
RECOMMENDATION_EMBEDDING_MODEL=text-embedding-3-large
RECOMMENDATION_EMBEDDING_DIMENSIONS=1536
RECOMMENDATION_LLM_MODEL=gpt-5-mini
RECOMMENDATION_HTTP_TIMEOUT_SECONDS=60
RECOMMENDATION_VECTOR_TOP_K=50
RECOMMENDATION_LLM_CANDIDATE_K=20
RECOMMENDATION_DEFAULT_TOP_N=10
RECOMMENDATION_CARD_MAX_CHARS=700
RECOMMENDATION_SCORE_THRESHOLD_ENABLED=true
RECOMMENDATION_MIN_SCORE_100=60
RECOMMENDATION_LLM_MAX_TOKENS=2200
# RECOMMENDATION_TEST_USER_TURN_ID=123
