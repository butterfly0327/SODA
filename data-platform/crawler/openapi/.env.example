# =========================
# 필수
# =========================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/your_db

# =========================
# 일반 동작 옵션
# =========================
OPENAPI_REQUEST_TIMEOUT_SECONDS=30
OPENAPI_USER_AGENT=Mozilla/5.0 (compatible; openapi-ingest/1.0)

# =========================
# 공공데이터포털 (datagokr) 전용
# =========================
# CSV 파일 경로 (공공데이터포털에서 내보낸 open_api 목록 CSV)
DATAGOKR_CSV_PATH=/path/to/openapi_list.csv
# 동시 요청 수 (기본 8)
DATAGOKR_CONCURRENCY=8
# 배치 크기 (기본 50)
DATAGOKR_BATCH_SIZE=50
